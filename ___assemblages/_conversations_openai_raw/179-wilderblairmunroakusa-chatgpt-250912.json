          "parts": [
            "{\"comments\":[{\"pattern\":\"## Canvas Demo Document\",\"comment\":\"Consider adding a short introductory sentence before the heading to give context about what this demo is for.\"},{\"pattern\":\"This is a short demo document so you can try out commenting.\",\"comment\":\"You might rephrase this to be a bit smoother, for example: 'Here’s a brief demo document where you can practice adding comments.'\"},{\"pattern\":\"- Suggest a rewrite of a sentence\",\"comment\":\"Perhaps combine these bullet points into one concise list without the example haiku, to keep the focus on the purpose of the demo.\"},{\"pattern\":\"Once you leave a comment, I’ll see it and can respond inline—or make edits to the doc itself.\",\"comment\":\"You could expand this closing sentence to also reassure the reader that comments can be resolved once addressed, mirroring collaborative tools.\"}]}"
          ]
        },
        "status": "finished_successfully",
        "end_turn": false,
        "weight": 1.0,
