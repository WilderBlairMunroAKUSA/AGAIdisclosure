        "create_time": 1722821058.186122,
        "update_time": null,
        "content": {
          "content_type": "text",
          "parts": [
            "In Latin, \"in case of war\" can be expressed as \"casu belli.\" This phrase translates directly to \"in the event of war\" or \"in the case of war.\" It is different from \"prepare for war,\" which is \"para bellum\" in Latin."
          ]
        },
